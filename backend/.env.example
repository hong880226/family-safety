# FamilySafety backend environment
# Copy to .env, fill in secrets, then start the service.
# In production, ENVIRONMENT must be 'prod' and JWT_SECRET must be a random
# string of at least 32 characters. The service refuses to start otherwise.

ENVIRONMENT=prod
DEBUG=false

# Use SQLite for quick dev only; for prod use Postgres.
DATABASE_URL=postgresql+asyncpg://familysafety:CHANGE_ME@db:5432/familysafety
REDIS_URL=redis://redis:6379/0

# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
JWT_SECRET=CHANGE_ME_GENERATE_WITH_python_c_secrets_token_urlsafe_32

# Fernet key for at-rest encryption (SMTP password, etc.). If unset, derived
# from JWT_SECRET (less ideal — set this explicitly in prod).
# Generate with: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
FERNET_KEY=

# 24h default. Sessions still revocable via password rotation.
JWT_EXPIRE_MINUTES=1440

# LLM (any OpenAI-compatible endpoint)
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=30

# CORS — explicit origins. NEVER use '*' in prod with credentials.
# Example: CORS_ORIGINS=["https://dashboard.example.com"]
CORS_ORIGINS=["https://dashboard.example.com"]
CORS_ALLOW_CREDENTIALS=true